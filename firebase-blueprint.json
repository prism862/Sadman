{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "isSpectrum": { "type": "boolean" },
        "spectrumImage": { "type": "string" },
        "isLimitedTime": { "type": "boolean" },
        "stockCount": { "type": "number" },
        "isOutOfStock": { "type": "boolean" },
        "offer": { "type": "number" }
      },
      "required": ["id", "title", "price", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "refunded"] },
        "customer": { "type": "object" },
        "deliveryArea": { "type": "string" },
        "deliveryFee": { "type": "number" }
      },
      "required": ["id", "date", "items", "total", "status", "customer"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings like banner images",
      "type": "object",
      "properties": {
        "spectrum": { "type": "string" },
        "essential": { "type": "string" },
        "accessories": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/settings/banners": {
      "schema": "Settings",
      "description": "Global banner settings"
    }
  }
}
