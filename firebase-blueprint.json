{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for sale in the shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "isSpectrum": { "type": "boolean" },
        "spectrumImage": { "type": "string" },
        "offer": { "type": "number" },
        "isLimitedTime": { "type": "boolean" },
        "stockCount": { "type": "number" },
        "isOutOfStock": { "type": "boolean" }
      },
      "required": ["id", "title", "price", "images", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "deliveryArea": { "type": "string", "enum": ["Inside Chittagong", "Outside Chittagong"] },
        "deliveryFee": { "type": "number" },
        "customer": { "type": "object" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "refunded"] }
      },
      "required": ["id", "items", "total", "customer", "date", "status"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global website configuration.",
      "type": "object",
      "properties": {
        "bannerImages": { "type": "object" },
        "deliveryFees": { "type": "object" },
        "adminPassword": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/settings/global": {
      "schema": "SiteSettings",
      "description": "Single document for site settings."
    }
  }
}
