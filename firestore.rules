rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId (string)
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - price: number (required)
    //   - description: string
    //   - images: list of strings (required)
    //   - category: string
    //   - sizes: list of strings
    //   - colors: list of strings
    //   - isSpectrum: bool
    //   - spectrumImage: string
    //   - isLimitedTime: bool
    //   - stockCount: number
    //   - isOutOfStock: bool
    //   - offer: number
    //
    // Collection: orders
    // Document ID: orderId (string)
    // Fields:
    //   - id: string (required)
    //   - date: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required, enum: pending, processing, shipped, delivered, refunded)
    //   - customer: map (required)
    //   - deliveryArea: string
    //   - deliveryFee: number
    //
    // Collection: settings
    // Document ID: banners
    // Fields:
    //   - spectrum: string
    //   - essential: string
    //   - accessories: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sadmanraisa123@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'images']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.images is list && data.images.size() <= 6;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'date', 'items', 'total', 'status', 'customer']) &&
             data.id is string &&
             data.date is string &&
             data.items is list &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'refunded'] &&
             data.customer is map;
    }

    function isValidSettings(data) {
      return data.keys().hasAny(['spectrum', 'essential', 'accessories']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
