rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - price: number (required, positive)
    //   - imageUrl: string (required, valid URL)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sadmanraisa123@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'images']) &&
             data.title is string && data.title.size() >= 1 &&
             data.price is number &&
             data.images is list &&
             (!('description' in data) || data.description is string) &&
             (!('category' in data) || data.category is string) &&
             (!('sizes' in data) || data.sizes is list) &&
             (!('colors' in data) || data.colors is list) &&
             (!('isSpectrum' in data) || data.isSpectrum is bool) &&
             (!('spectrumImage' in data) || data.spectrumImage is string) &&
             (!('isLimitedTime' in data) || data.isLimitedTime is bool) &&
             (!('stockCount' in data) || data.stockCount is number) &&
             (!('isOutOfStock' in data) || data.isOutOfStock is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      // Publicly readable so customers can see products
      allow read: if true;
      
      // Allow writes for any authenticated user (including anonymous)
      // This supports the password-only access requested by the user
      allow create: if request.auth != null && isValidProduct(request.resource.data);
      allow update: if request.auth != null && isValidProduct(request.resource.data);
      allow delete: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if true; // Allow customers to place orders
      allow update, delete: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
