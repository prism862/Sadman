// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: products
// Document ID: productId
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - price: number (required)
//   - description: string
//   - images: list of strings (required)
//   - category: string (required)
//   - sizes: list of strings
//   - isSpectrum: bool
//   - spectrumImage: string
//   - offer: number
//   - isLimitedTime: bool
//   - stockCount: number
//   - isOutOfStock: bool
//
// Collection: orders
// Document ID: orderId
// Fields:
//   - id: string (required)
//   - items: list (required)
//   - total: number (required)
//   - deliveryArea: string (required)
//   - deliveryFee: number
//   - customer: map (required)
//   - date: string (required)
//   - status: string (required)
//
// Collection: settings
// Document ID: global
// Fields:
//   - bannerImages: map
//   - deliveryFees: map
//   - adminPassword: string
//   - contactPhone: string
//   - contactEmail: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "sadmanraisa123@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'images', 'category']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.images is list && data.images.size() <= 6 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'customer', 'date', 'status']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.customer is map &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'refunded'];
    }

    function isValidSettings(data) {
      return data.bannerImages is map &&
             data.deliveryFees is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
